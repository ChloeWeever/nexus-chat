{
  "name": "nexus-chat",
  "version": "1.0.0",
  "description": "AI Chat Desktop App powered by LiteLLM",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
